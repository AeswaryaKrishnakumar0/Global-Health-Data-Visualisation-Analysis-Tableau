      <column caption='Year' datatype='date' name='[date]' role='dimension' type='quantitative' />
      <column caption='Dimension' datatype='string' name='[dimension]' role='dimension' type='nominal' />
      <column caption='Value' datatype='real' name='[estimate]' role='measure' type='quantitative' />
